{
  "name": "qtum-snap",
  "version": "1.0.0-beta.16",
  "description": "Qtum Wallet acts as an RPC proxy, forwarding MetaMask requests to the Qtum network via the Qtum ethers adapter. To function securely, it requires the snap_getBip32Entropy permission (specifically for path m/44'/88'). This provides the benefit of deriving your local Qtum addresses and securely signing transactions directly within the Snap. The risk is limited to this specific Qtum derivation path, ensuring your main Ethereum keys and core recovery phrase remain isolated and unexposed.",
  "repository": {
    "type": "git",
    "url": "https://github.com/qtumproject/qtum-extension-wallet.git"
  },
  "license": "(MIT-0 OR Apache-2.0)",
  "files": [
    "dist/**/*",
    "images/**/*",
    "snap.manifest.json",
    "README.md"
  ],
  "scripts": {
    "build": "yarn clean && node build.js && yarn build:post && yarn bundle:eval && yarn bundle:manifest",
    "build:clean": "yarn clean && yarn build",
    "build:post": "node post-process.js",
    "bundle:eval": "mm-snap eval",
    "bundle:manifest": "mm-snap manifest --fix",
    "clean": "rimraf dist",
    "generate-ether-types": "typechain --target=ethers-v5 'abis/**/*.json' --out-dir src/types/contracts",
    "lint": "yarn lint:eslint && yarn lint:misc --check",
    "lint:eslint": "eslint . --cache --ext js,ts",
    "lint:fix": "yarn lint:eslint --fix && yarn lint:misc --write",
    "lint:misc": "prettier '**/*.json' '**/*.md' '!CHANGELOG.md' --ignore-path .gitignore",
    "prepublishOnly": "yarn && yarn build",
    "serve": "mm-snap serve",
    "start": "nodemon --watch src/ --ext ts,tsx --exec 'yarn build && yarn serve'",
    "test": "jest",
    "typia:generate": "typia generate --input src/typia-templates --output src/typia-generated --project tsconfig.json",
    "preversion": "yarn && yarn build && git add snap.manifest.json"
  },
  "dependencies": {
    "@distributedlab/tools": "1.0.0-rc.17",
    "@ethersproject/abstract-provider": "5.8.0",
    "@ethersproject/abstract-signer": "5.8.0",
    "@ethersproject/properties": "5.8.0",
    "@metamask/gas-fee-controller": "25.0.0",
    "@metamask/key-tree": "10.1.1",
    "@metamask/metamask-eth-abis": "3.1.1",
    "@metamask/network-controller": "25.0.0",
    "@metamask/snaps-jest": "9.5.1",
    "@metamask/snaps-sdk": "10.4.0",
    "@metamask/snaps-utils": "11.6.1",
    "@metamask/transaction-controller": "61.1.0",
    "@types/react": "19.2.6",
    "@types/react-dom": "19.2.3",
    "bip38": "3.1.1",
    "buffer": "6.0.3",
    "eth-block-tracker": "8.1.0",
    "ethers": "5.8.0",
    "intl": "1.2.5",
    "key-did-provider-ed25519": "3.0.2",
    "key-did-resolver": "3.0.0",
    "lodash": "4.17.23",
    "qrcode": "1.5.4",
    "qtum-ethers-wrapper": "2.1.2",
    "qtum-snap-connector": "workspace:^",
    "qtumjs-lib": "0.0.8",
    "setimmediate": "1.0.5",
    "typia": "4.1.3",
    "uuid": "9.0.0",
    "wif": "2.0.6"
  },
  "devDependencies": {
    "@jest/globals": "29.5.0",
    "@lavamoat/allow-scripts": "2.0.3",
    "@metamask/auto-changelog": "5.1.0",
    "@metamask/snaps-cli": "8.3.0",
    "@types/intl": "1.2.0",
    "@types/lodash": "4.17.7",
    "@types/qrcode": "1",
    "@types/uuid": "9.0.2",
    "@typescript-eslint/eslint-plugin": "5.33.0",
    "@typescript-eslint/parser": "5.33.0",
    "esbuild": "0.25.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "8.10.0",
    "eslint-plugin-import": "2.29.1",
    "eslint-plugin-jest": "26.8.2",
    "eslint-plugin-jsdoc": "41.1.2",
    "eslint-plugin-n": "15.7.0",
    "eslint-plugin-node": "11.1.0",
    "eslint-plugin-prettier": "4.2.1",
    "node-stdlib-browser": "1.2.0",
    "nodemon": "2.0.20",
    "npm-commands": "1.2.1",
    "prettier": "2.8.8",
    "rimraf": "5.0.10",
    "typescript": "5.8.3"
  },
  "packageManager": "yarn@3.2.1",
  "engines": {
    "node": ">=16.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
